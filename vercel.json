{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/home", "dest": "/index.html" },
    { "src": "/about", "dest": "/about-twibc.html" },
    { "src": "/programs", "dest": "/academic-programs.html" },
    { "src": "/admissions", "dest": "/admissions.html" },
    { "src": "/registration", "dest": "/registration.html" },
    { "src": "/campuses", "dest": "/campuses.html" },
    { "src": "/student-life", "dest": "/student-life.html" },
    { "src": "/alumni", "dest": "/alumni.html" },
    { "src": "/contact", "dest": "/contact-us.html" },
    { "src": "/student-portal", "dest": "/student-portal.html" },
    { "src": "/instructor-portal", "dest": "/instructor-portal.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
